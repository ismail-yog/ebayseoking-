# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# eBay API Configuration
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret
EBAY_REDIRECT_URI=https://your-domain.com/api/auth/callback/ebay
EBAY_RU_NAME=your-ebay-runame

# Upstash QStash Configuration
QSTASH_URL=https://qstash.upstash.io/v1/publish
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-qstash-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-qstash-next-signing-key

# Anthropic API Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key

# Encryption Key (Must be 32 bytes hex - e.g., 64 characters)
# Generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff
